Cell[CellGroupData[{
Cell["Construct SU(N) generators", "Section",
 CellChangeTimes->{{3.986077107059183*^9, 3.9860771174955864`*^9}, 
   3.986077161235626*^9},ExpressionUUID->"3e010ce6-96dd-4148-9f54-\
a027bb3d09f5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "SUNGenerators", "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SUNGenerators", "[", 
   RowBox[{"n_Integer", "/;", 
    RowBox[{"n", ">=", "2"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"sym", ",", "asym", ",", "diag"}], "}"}], ",", 
    RowBox[{"(*", 
     RowBox[{"1.", " ", "Symmetric", " ", 
      RowBox[{"(", 
       RowBox[{"Off", "-", "Diagonal"}], ")"}], " ", "Matrices"}], "*)"}], 
    RowBox[{
     RowBox[{"sym", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Normal", "@", 
           RowBox[{"SparseArray", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"j", ",", "k"}], "}"}], "->", "1"}], ",", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"k", ",", "j"}], "}"}], "->", "1"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"n", ",", "n"}], "}"}]}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", 
            RowBox[{"n", "-", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{"j", "+", "1"}], ",", "n"}], "}"}]}], "]"}], ",", "1"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"2.", " ", "Antisymmetric", " ", 
       RowBox[{"(", 
        RowBox[{"Off", "-", "Diagonal"}], ")"}], " ", "Matrices"}], "*)"}], 
     RowBox[{"asym", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Normal", "@", 
           RowBox[{"SparseArray", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"j", ",", "k"}], "}"}], "->", 
                RowBox[{"-", "I"}]}], ",", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"k", ",", "j"}], "}"}], "->", "I"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"n", ",", "n"}], "}"}]}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", 
            RowBox[{"n", "-", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{"j", "+", "1"}], ",", "n"}], "}"}]}], "]"}], ",", "1"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"3.", " ", "Diagonal", " ", "Matrices"}], "*)"}], 
     RowBox[{"diag", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{"2", "/", 
           RowBox[{"(", 
            RowBox[{"m", "*", 
             RowBox[{"(", 
              RowBox[{"m", "+", "1"}], ")"}]}], ")"}]}], "]"}], "*", 
         RowBox[{"Normal", "@", 
          RowBox[{"SparseArray", "[", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"i", ",", "i"}], "}"}], "->", "1"}], ",", 
                RowBox[{"{", 
                 RowBox[{"i", ",", "1", ",", "m"}], "}"}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"m", "+", "1"}], ",", 
                  RowBox[{"m", "+", "1"}]}], "}"}], "->", 
                RowBox[{"-", "m"}]}], "}"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"n", ",", "n"}], "}"}]}], "]"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"m", ",", "1", ",", 
          RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "Combine", " ", "all", " ", "matrices", " ", "into", " ", "a", " ", 
       "single", " ", "list"}], "*)"}], 
     RowBox[{"Join", "[", 
      RowBox[{"sym", ",", "asym", ",", "diag"}], "]"}]}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9860758690357914`*^9, 3.9860758690357914`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"11df4ce8-f2e6-714d-832a-4046bc2e1e90"],

